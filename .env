# Deployment Configuration
# Copy this file to .env and edit the values

# Domain Settings
FRONTEND_DOMAIN=aie223.need.cat
BACKEND_DOMAIN=aie223api.need.cat

# Ports (for local development or port-based deployment)
FRONTEND_PORT=1660
BACKEND_PORT=1693

# API Configuration
# Use '/api' for same-domain proxy setup
# Use full URL (e.g., https://aie223api.need.cat) for separate domain setup
VITE_API_URL=/api

# Backend Settings
BACKEND_PORT_CONTAINER=5000
WORKERS=2
TIMEOUT=120
